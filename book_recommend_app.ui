  <property name="styleSheet">
   <string notr="true">
QWidget#BookRecommendApp {
    background-color: #f4f6fa;
}
QWidget#header {
    background-color: #ffffff;
    border-bottom: 1px solid #e8eaf0;
}
QLabel#logoLabel {
    font-size: 22px;
    font-weight: bold;
    color: #111111;
    background-color: transparent;
}
QLabel#headerTitle {
    font-size: 13px;
    font-weight: bold;
    color: #041242;
    background-color: transparent;
}
QLabel#headerRight {
    background-color: transparent;
}
QWidget#searchArea {
    background-color: #041242;
}
QLabel#searchSubtitle {
    color: #66BEFF;
    font-size: 11px;
    background-color: transparent;
}
QLabel#searchTitle {
    color: #ffffff;
    font-size: 15px;
    font-weight: bold;
    background-color: transparent;
}
QLineEdit#searchInput {
    background-color: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 13px;
    color: #111111;
    min-height: 30px;
}
QPushButton#searchBtn {
    background-color: #EC1929;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: bold;
    min-height: 34px;
    min-width: 64px;
    padding: 0 14px;
}
QPushButton#searchBtn:hover { background-color: #c41522; }
QWidget#filterCard {
    background-color: #ffffff;
    border: 1px solid #d8dce8;
    border-radius: 8px;
}
QLabel#authorLabel, QLabel#countryLabel, QLabel#genreLabel {
    font-size: 12px;
    font-weight: bold;
    color: #041242;
    background-color: transparent;
    min-width: 64px;
}
QLineEdit#authorInput {
    background-color: #ffffff;
    border: 1px solid #d0d5e0;
    border-radius: 5px;
    padding: 3px 10px;
    font-size: 12px;
    color: #222222;
    min-height: 26px;
}
QComboBox#countryCombo {
    background-color: #ffffff;
    border: 1px solid #d0d5e0;
    border-radius: 5px;
    padding: 3px 8px;
    font-size: 12px;
    color: #222222;
    min-height: 26px;
    min-width: 120px;
    max-width: 160px;
}
QCheckBox {
    font-size: 12px;
    color: #444444;
    background-color: #f8f9fb;
    border: 1px solid #d0d5e0;
    border-radius: 12px;
    padding: 4px 10px;
    spacing: 0px;
}
QCheckBox:checked {
    color: #0043FF;
    background-color: #deeeff;
    border: 1px solid #0080FF;
    font-weight: bold;
}
QCheckBox::indicator { width: 0px; height: 0px; }
QWidget#resultsBox {
    background-color: #ffffff;
    border: 1px solid #d8dce8;
    border-radius: 8px;
}
QLabel#resultsLabel {
    font-size: 12px;
    font-weight: bold;
    color: #041242;
    background-color: transparent;
}
QLabel#resultCount {
    font-size: 11px;
    color: #888888;
    background-color: transparent;
}
QLabel#emptyLabel {
    color: #aaaaaa;
    font-size: 13px;
    background-color: transparent;
}
QPushButton#actionBtn {
    background-color: #0080FF;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: bold;
    min-height: 36px;
    min-width: 110px;
    padding: 0 20px;
}
QPushButton#actionBtn:hover { background-color: #0066cc; }
QScrollArea { border: none; background-color: transparent; }
QScrollBar:vertical { width: 6px; background: transparent; }
QScrollBar::handle:vertical { background: #d0d5e0; border-radius: 3px; min-height: 20px; }
