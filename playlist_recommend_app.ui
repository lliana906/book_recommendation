  <property name="styleSheet">
   <string notr="true">
QDialog#PlaylistRecommendDialog {
    background-color: #f4f6fa;
}
QWidget#dialogHeader {
    background-color: #041242;
}
QLabel#headerSubtitle {
    color: #66BEFF;
    font-size: 11px;
    background-color: transparent;
}
QLabel#headerTitle {
    color: #ffffff;
    font-size: 15px;
    font-weight: bold;
    background-color: transparent;
}
QWidget#bookSummaryCard {
    background-color: #ffffff;
    border: 1px solid #d8dce8;
    border-radius: 8px;
}
QLabel#bookCover {
    background-color: #0043FF;
    border-radius: 4px;
}
QLabel#bookTitleLabel {
    font-size: 14px;
    font-weight: bold;
    color: #111111;
    background-color: transparent;
}
QLabel#bookAuthorLabel {
    font-size: 12px;
    color: #666666;
    background-color: transparent;
}
QLabel#genreBadge {
    font-size: 11px;
    font-weight: bold;
    color: #0043FF;
    background-color: #deeeff;
    border-radius: 10px;
    padding: 2px 10px;
}
QLabel#sectionLabel {
    font-size: 12px;
    font-weight: bold;
    color: #041242;
    background-color: transparent;
}
QWidget#playlistCard {
    background-color: #ffffff;
    border: 1px solid #d8dce8;
    border-radius: 8px;
}
QWidget#playlistCard:hover {
    border: 1px solid #0080FF;
}
QLabel#playlistThumb, QLabel#playlistThumb2, QLabel#playlistThumb3 {
    background-color: #EC1929;
    border-radius: 6px;
}
QLabel#playlistTitle, QLabel#playlistTitle1, QLabel#playlistTitle2, QLabel#playlistTitle3 {
    font-size: 13px;
    font-weight: bold;
    color: #111111;
    background-color: transparent;
}
QLabel#playlistChannel, QLabel#playlistChannel1, QLabel#playlistChannel2, QLabel#playlistChannel3 {
    font-size: 11px;
    color: #888888;
    background-color: transparent;
}
QLabel#playlistTag, QLabel#playlistTag1, QLabel#playlistTag2, QLabel#playlistTag3 {
    font-size: 10px;
    font-weight: bold;
    color: #EC1929;
    background-color: #ffe5e8;
    border-radius: 9px;
    padding: 2px 8px;
}
QPushButton#playBtn, QPushButton#playBtn1, QPushButton#playBtn2, QPushButton#playBtn3 {
    background-color: #EC1929;
    color: #ffffff;
    border: none;
    border-radius: 14px;
    font-size: 12px;
    font-weight: bold;
    min-height: 28px;
    min-width: 60px;
}
QPushButton#playBtn:hover, QPushButton#playBtn1:hover, QPushButton#playBtn2:hover, QPushButton#playBtn3:hover { background-color: #c41522; }
QPushButton#closeBtn {
    background-color: #ffffff;
    color: #555555;
    border: 1px solid #d0d5e0;
    border-radius: 6px;
    font-size: 13px;
    font-weight: bold;
    min-height: 36px;
    min-width: 90px;
}
QPushButton#closeBtn:hover { background-color: #f0f2f6; }
QPushButton#openYoutubeBtn {
    background-color: #0080FF;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: bold;
    min-height: 36px;
    min-width: 140px;
    padding: 0 16px;
}
QPushButton#openYoutubeBtn:hover { background-color: #0066cc; }
QScrollArea { border: none; background-color: transparent; }
QScrollBar:vertical { width: 6px; background: transparent; }
QScrollBar::handle:vertical { background: #d0d5e0; border-radius: 3px; min-height: 20px; }
